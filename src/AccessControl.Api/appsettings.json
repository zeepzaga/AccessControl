{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "AccessControlDb": "Host=localhost;Database=access_control;Username=postgres;Password=postgres"
  },
  "DeviceIntegration": {
    "Mode": "Http",
    "Mqtt": {
      "Host": "localhost",
      "Port": 1883,
      "TopicSubscribe": "accesscontrol/cards/read",
      "TopicPublishPrefix": "accesscontrol/cards/response"
    }
  },
  "Biometric": {
    "Local": {
      "MatchThreshold": 0.42
    }
  },
  "Auth": {
    "Jwt": {
      "Issuer": "AccessControl.Api",
      "Audience": "AccessControl.Clients",
      "SigningKey": "dev-signing-key-change-me-please-1234567890",
      "AccessTokenLifetimeMinutes": 480,
      "RefreshTokenLifetimeDays": 30
    },
    "BootstrapAdmin": {
      "Email": "admin@accesscontrol.local",
      "Password": "AccessControl123!",
      "FullName": "System Administrator"
    }
  }
}
