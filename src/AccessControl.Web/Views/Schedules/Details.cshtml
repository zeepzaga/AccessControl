@model AccessControl.Domain.Entities.Schedule
@{
    ViewData["Title"] = "Расписание";
    var rules = ViewBag.AccessRules as IEnumerable<AccessControl.Domain.Entities.AccessRule> ?? Enumerable.Empty<AccessControl.Domain.Entities.AccessRule>();
}

<h2>Расписание</h2>

<dl class="row">
    <dt class="col-sm-3">Название</dt>
    <dd class="col-sm-9">@Model.Name</dd>
</dl>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">Расписание</h5>
        <div id="schedulePretty">Загрузка...</div>
    </div>
</div>

<div class="mb-3">
    <label class="form-label">JSON</label>
    <pre class="bg-soft p-3 border" id="scheduleJsonRaw">@Model.ScheduleJson</pre>
</div>

@if (rules.Any())
{
    <h5>Связанные правила</h5>
    <ul>
        @foreach (var rule in rules)
        {
            <li>@(rule.Employee?.FullName ?? "Сотрудник не указан") — @(rule.AccessPoint?.Name ?? "Точка доступа не указана")</li>
        }
    </ul>
}

<p>
    <a class="btn btn-secondary" asp-action="Index">Назад</a>
    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Изменить</a>
</p>

@section Scripts {
<script>
(function () {
    const raw = document.getElementById('scheduleJsonRaw').innerText;
    const target = document.getElementById('schedulePretty');
    try {
        const data = JSON.parse(raw);
        const dayMap = {
            1: 'Пн', 2: 'Вт', 3: 'Ср', 4: 'Чт', 5: 'Пт', 6: 'Сб', 7: 'Вс'
        };

        let html = '';
        html += `<div><strong>Часовой пояс:</strong> ${data.timezone || 'UTC'}</div>`;
        html += `<div><strong>Доступ по умолчанию:</strong> ${data.defaultAccess ? 'Разрешён' : 'Запрещён'}</div>`;

        if (Array.isArray(data.weeklyRules) && data.weeklyRules.length) {
            html += '<hr/><div><strong>Правила недели:</strong></div>';
            data.weeklyRules.forEach((rule) => {
                const days = (rule.days || []).map(d => dayMap[d] || d).join(', ');
                const intervals = (rule.intervals || []).map(i => `${i.from}–${i.to}`).join(', ');
                html += `<div class="mt-2">${days || '—'}: ${intervals || '—'}</div>`;
            });
        }

        if (Array.isArray(data.dateOverrides) && data.dateOverrides.length) {
            html += '<hr/><div><strong>Исключения по датам:</strong></div>';
            data.dateOverrides.forEach((d) => {
                html += `<div class="mt-2">${d.date}: ${d.access ? 'Разрешён' : 'Запрещён'}</div>`;
            });
        }

        target.innerHTML = html;
    } catch {
        target.textContent = 'Ошибка чтения расписания';
    }
})();
</script>
}
