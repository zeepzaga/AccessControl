@model AccessControl.Domain.Entities.Schedule
@{
    ViewData["Title"] = "Удалить расписание";
}

<h2>Удалить расписание</h2>

<div class="alert alert-warning">
    Вы уверены, что хотите удалить расписание <strong>@Model.Name</strong>?
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Удалить</button>
    <a class="btn btn-secondary" asp-action="Index">Отмена</a>
</form>
