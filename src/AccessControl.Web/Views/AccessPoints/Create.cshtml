@model AccessControl.Web.Models.AccessPointFormModel
@{
    ViewData["Title"] = "Добавить точку доступа";
}

<h2>Добавить точку доступа</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="Name" class="form-label">Название</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Location" class="form-label">Расположение</label>
        <input asp-for="Location" class="form-control" />
    </div>
    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label">Активна</label>
    </div>
    <div class="form-check mb-4">
        <input asp-for="IsGuestAccess" class="form-check-input" />
        <label asp-for="IsGuestAccess" class="form-check-label">Разрешить гостевые карты</label>
    </div>

    <div class="row g-4">
        <div class="col-12 col-lg-6">
            <div class="selection-panel">
                <label class="form-label mb-1">Департаменты с доступом</label>
                <div class="form-text mb-3">Все сотрудники из выбранных департаментов получат доступ к этой точке без отдельного правила.</div>
                <input type="search" class="form-control mb-3" placeholder="Поиск по названию департамента" data-selection-search-input="departments" />
                <div class="selection-list" data-selection-search-target="departments">
                    @foreach (var department in Model.AvailableDepartments)
                    {
                        <label class="selection-item" data-filter-text="@department.SearchText.ToLowerInvariant()">
                            <input class="form-check-input" type="checkbox" name="SelectedDepartmentIds" value="@department.Id" checked="@department.Selected" />
                            <span>@department.Label</span>
                        </label>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="selection-panel">
                <label class="form-label mb-1">Сотрудники с прямым доступом</label>
                <div class="form-text mb-3">Выбранные сотрудники получат отдельную связь с этой точкой доступа. Расписания и ограничения задаются отдельно в разделе «Правила доступа».</div>
                <input type="search" class="form-control mb-3" placeholder="Поиск по ФИО сотрудника" data-selection-search-input="employees" />
                <div class="selection-list" data-selection-search-target="employees">
                    @foreach (var employee in Model.AvailableEmployees)
                    {
                        <label class="selection-item" data-filter-text="@employee.SearchText.ToLowerInvariant()">
                            <input class="form-check-input" type="checkbox" name="SelectedEmployeeIds" value="@employee.Id" checked="@employee.Selected" />
                            <span>@employee.Label</span>
                        </label>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4 d-flex flex-wrap gap-2">
        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a class="btn btn-secondary" asp-action="Index">Отмена</a>
    </div>
</form>