@model AccessControl.Domain.Entities.AccessPoint
@{
    ViewData["Title"] = "Точка доступа";
    var rules = ViewBag.AccessRules as IEnumerable<AccessControl.Domain.Entities.AccessRule> ?? Enumerable.Empty<AccessControl.Domain.Entities.AccessRule>();
    var eventsList = ViewBag.RecentEvents as IEnumerable<AccessControl.Domain.Entities.AccessEvent> ?? Enumerable.Empty<AccessControl.Domain.Entities.AccessEvent>();
}

<h2>Точка доступа</h2>

<dl class="row">
    <dt class="col-sm-3">Название</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">Расположение</dt>
    <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Location) ? "Не указано" : Model.Location)</dd>

    <dt class="col-sm-3">Статус</dt>
    <dd class="col-sm-9">@(Model.IsActive ? "Активна" : "Неактивна")</dd>

    <dt class="col-sm-3">Гостевой доступ</dt>
    <dd class="col-sm-9">@(Model.IsGuestAccess ? "Разрешён" : "Запрещён")</dd>

    <dt class="col-sm-3">Департаменты</dt>
    <dd class="col-sm-9">@(Model.DepartmentNames.Any() ? string.Join(", ", Model.DepartmentNames) : "Не назначены")</dd>

    <dt class="col-sm-3">Сотрудники</dt>
    <dd class="col-sm-9">
        @(Model.EmployeeAccessPoints.Any(link => link.Employee != null)
            ? string.Join(", ", Model.EmployeeAccessPoints.Where(link => link.Employee != null).Select(link => link.Employee!.FullName).OrderBy(name => name))
            : "Не назначены")
    </dd>
</dl>

@if (rules.Any())
{
    <h5>Правила доступа</h5>
    <ul>
        @foreach (var rule in rules)
        {
            <li>
                @(rule.Schedule?.Name ?? "Без расписания")
                (@(rule.ValidFrom?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "Сразу") - @(rule.ValidTo?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "Без окончания"))
            </li>
        }
    </ul>
}

@if (eventsList.Any())
{
    <h5>Последние события</h5>
    <ul>
        @foreach (var ev in eventsList)
        {
            <li>@ev.EventTime.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss") - @(ev.Employee?.FullName ?? "Неизвестный сотрудник") (@ev.Reason)</li>
        }
    </ul>
}

<p>
    <a class="btn btn-secondary" asp-action="Index">Назад</a>
    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Изменить</a>
    <a class="btn btn-outline-primary" asp-controller="AccessRules" asp-action="Index" asp-route-accessPointId="@Model.Id">Все правила этой точки</a>
</p>