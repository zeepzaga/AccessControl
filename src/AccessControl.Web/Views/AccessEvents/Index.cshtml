@model AccessControl.Web.Models.PagedListViewModel<AccessControl.Domain.Entities.AccessEvent>
@{
    ViewData["Title"] = "∆урнал событий";
    var currentSort = ViewBag.Sort as string ?? "eventtime";
    var currentDesc = ViewBag.Desc is bool b && b;
    var defaultColumns = new[] { "event_time", "card_uid", "employee_name", "access_point", "device", "access_granted", "reason" };
    var cardUid = ViewBag.CardUid as string;
    Guid? accessPointId = ViewBag.AccessPointId is Guid accessPointIdValue ? accessPointIdValue : null;
    Guid? employeeId = ViewBag.EmployeeId is Guid employeeIdValue ? employeeIdValue : null;
    bool? granted = ViewBag.Granted is bool grantedValue ? grantedValue : null;
    var reason = ViewBag.Reason as string;
    var cardOptions = ViewBag.CardOptions as IEnumerable<AccessControl.Web.Models.SearchableSelectOptionViewModel> ?? Enumerable.Empty<AccessControl.Web.Models.SearchableSelectOptionViewModel>();
    var employeeOptions = ViewBag.EmployeeOptions as IEnumerable<AccessControl.Web.Models.SearchableSelectOptionViewModel> ?? Enumerable.Empty<AccessControl.Web.Models.SearchableSelectOptionViewModel>();
    var accessPointOptions = ViewBag.AccessPointOptions as IEnumerable<AccessControl.Web.Models.SearchableSelectOptionViewModel> ?? Enumerable.Empty<AccessControl.Web.Models.SearchableSelectOptionViewModel>();
    var fromUtc = ViewBag.FromUtc is DateTime fromValue ? fromValue.ToString("yyyy-MM-ddTHH:mm") : string.Empty;
    var toUtc = ViewBag.ToUtc is DateTime toValue ? toValue.ToString("yyyy-MM-ddTHH:mm") : string.Empty;

    string TranslateReason(object? reasonValue) => reasonValue?.ToString() switch
    {
        "OK" => "–азрешено",
        "CardNotFound" => " арта не найдена",
        "AccessDenied" => "ƒоступ запрещЄн",
        "ScheduleDenied" => "«апрещено расписанием",
        "CardExpired" => " арта просрочена",
        "DeviceUnknown" => "Ќеизвестное устройство",
        "BiometricFailed" => "Ѕиометри€ не пройдена",
        _ => reasonValue?.ToString() ?? "Ч"
    };

    string SortUrl(string column) => Url.Action("Index", new
    {
        cardUid,
        accessPointId,
        employeeId,
        granted,
        reason,
        fromUtc = string.IsNullOrWhiteSpace(fromUtc) ? null : fromUtc,
        toUtc = string.IsNullOrWhiteSpace(toUtc) ? null : toUtc,
        sort = column,
        desc = currentSort == column ? !currentDesc : false,
        page = 1,
        pageSize = Model.PageSize
    }) ?? "#";

    string PageUrl(int page) => Url.Action("Index", new
    {
        cardUid,
        accessPointId,
        employeeId,
        granted,
        reason,
        fromUtc = string.IsNullOrWhiteSpace(fromUtc) ? null : fromUtc,
        toUtc = string.IsNullOrWhiteSpace(toUtc) ? null : toUtc,
        sort = currentSort,
        desc = currentDesc,
        page,
        pageSize = Model.PageSize
    }) ?? "#";
}

<h2>∆урнал событий</h2>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">‘ильтр</h5>
        <form method="get" class="row g-3">
            <input type="hidden" name="sort" value="@currentSort" />
            <input type="hidden" name="desc" value="@currentDesc.ToString().ToLowerInvariant()" />
            <input type="hidden" name="pageSize" value="@Model.PageSize" />
            <div class="col-12 col-md-4">
                <label class="form-label">UID карты</label>
                <div class="searchable-select">
                    <input type="search" class="form-control searchable-select-filter" placeholder="Ќачните вводить UID карты" data-select-filter-input="event-card" />
                    <select name="cardUid" class="form-select" data-select-filter-target="event-card">
                        <option value="">¬се карты</option>
                        @foreach (var option in cardOptions)
                        {
                            <option value="@option.Value" data-filter-text="@option.SearchText.ToLowerInvariant()" selected="@option.Selected">@option.Label</option>
                        }
                    </select>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label">“очка доступа</label>
                <div class="searchable-select">
                    <input type="search" class="form-control searchable-select-filter" placeholder="Ќачните вводить название точки доступа" data-select-filter-input="event-accesspoint" />
                    <select name="accessPointId" class="form-select" data-select-filter-target="event-accesspoint">
                        <option value="">¬се точки доступа</option>
                        @foreach (var option in accessPointOptions)
                        {
                            <option value="@option.Value" data-filter-text="@option.SearchText.ToLowerInvariant()" selected="@option.Selected">@option.Label</option>
                        }
                    </select>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label">—отрудник</label>
                <div class="searchable-select">
                    <input type="search" class="form-control searchable-select-filter" placeholder="Ќачните вводить ‘»ќ сотрудника" data-select-filter-input="event-employee" />
                    <select name="employeeId" class="form-select" data-select-filter-target="event-employee">
                        <option value="">¬се сотрудники</option>
                        @foreach (var option in employeeOptions)
                        {
                            <option value="@option.Value" data-filter-text="@option.SearchText.ToLowerInvariant()" selected="@option.Selected">@option.Label</option>
                        }
                    </select>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label">–езультат</label>
                <select name="granted" class="form-select">
                    <option value="">Ћюбой</option>
                    <option value="true" selected="@(granted == true)">–азрешЄн</option>
                    <option value="false" selected="@(granted == false)">«апрещЄн</option>
                </select>
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label">ѕричина</label>
                <select name="reason" class="form-select">
                    <option value="">Ћюба€</option>
                    <option value="OK" selected="@(reason == "OK")">–азрешено</option>
                    <option value="CardNotFound" selected="@(reason == "CardNotFound")"> арта не найдена</option>
                    <option value="AccessDenied" selected="@(reason == "AccessDenied")">ƒоступ запрещЄн</option>
                    <option value="ScheduleDenied" selected="@(reason == "ScheduleDenied")">«апрещено расписанием</option>
                    <option value="CardExpired" selected="@(reason == "CardExpired")"> арта просрочена</option>
                    <option value="DeviceUnknown" selected="@(reason == "DeviceUnknown")">Ќеизвестное устройство</option>
                    <option value="BiometricFailed" selected="@(reason == "BiometricFailed")">Ѕиометри€ не пройдена</option>
                </select>
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label">— даты (UTC)</label>
                <input type="datetime-local" name="fromUtc" value="@fromUtc" class="form-control" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label">ѕо дату (UTC)</label>
                <input type="datetime-local" name="toUtc" value="@toUtc" class="form-control" />
            </div>
            <div class="col-12 d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-primary">ѕрименить</button>
                <a class="btn btn-outline-secondary" href="@Url.Action("Index")">—бросить</a>
            </div>
        </form>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">Ёкспорт</h5>
        <form method="get" asp-action="Export" class="row g-3">
            <div class="col-12 col-md-3">
                <label class="form-label">‘ормат</label>
                <select name="format" class="form-select">
                    <option value="csv">CSV</option>
                    <option value="xlsx">XLSX</option>
                </select>
            </div>
            <div class="col-12 col-md-9">
                <label class="form-label"> олонки</label>
                <div class="d-flex flex-wrap gap-3">
                    @foreach (var col in defaultColumns)
                    {
                        var label = col switch
                        {
                            "event_time" => "¬рем€",
                            "card_uid" => "UID карты",
                            "employee_name" => "—отрудник",
                            "access_point" => "“очка доступа",
                            "device" => "”стройство",
                            "access_granted" => "–езультат",
                            "reason" => "ѕричина",
                            _ => col
                        };
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="columns" value="@col" checked />
                            <label class="form-check-label">@label</label>
                        </div>
                    }
                </div>
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label">— даты (UTC)</label>
                <input type="datetime-local" name="fromUtc" class="form-control" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label">ѕо дату (UTC)</label>
                <input type="datetime-local" name="toUtc" class="form-control" />
            </div>
            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Ёкспортировать</button>
                <a class="btn btn-outline-secondary" href="@Url.Action("Export", new { format = "csv" })">Ѕыстрый CSV</a>
            </div>
        </form>
    </div>
</div>

<div class="table-toolbar d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-3">
    <form method="get" class="d-flex align-items-center gap-2 flex-nowrap table-page-size-form">
        <input type="hidden" name="cardUid" value="@cardUid" />
        <input type="hidden" name="accessPointId" value="@accessPointId" />
        <input type="hidden" name="employeeId" value="@employeeId" />
        <input type="hidden" name="granted" value="@granted?.ToString()?.ToLowerInvariant()" />
        <input type="hidden" name="reason" value="@reason" />
        <input type="hidden" name="fromUtc" value="@fromUtc" />
        <input type="hidden" name="toUtc" value="@toUtc" />
        <input type="hidden" name="sort" value="@currentSort" />
        <input type="hidden" name="desc" value="@currentDesc.ToString().ToLowerInvariant()" />
        <input type="hidden" name="page" value="1" />
        <label class="small text-muted text-nowrap" for="eventPageSize">ќтображать на странице</label>
        <select id="eventPageSize" name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()">
            @foreach (var size in Model.PageSizeOptions)
            {
                <option value="@size" selected="@(size == Model.PageSize)">@size</option>
            }
        </select>
    </form>
    <div class="small text-muted">ѕоказаны записи @Model.StartItem-@Model.EndItem из @Model.TotalCount</div>
</div>

<div class="table-responsive">
    <table class="table table-modern align-middle">
        <thead>
        <tr>
            <th><a class="sort-link" href="@SortUrl("eventtime")">¬рем€ @(currentSort == "eventtime" ? (currentDesc ? "°" : "^") : string.Empty)</a></th>
            <th><a class="sort-link" href="@SortUrl("uid")">UID @(currentSort == "uid" ? (currentDesc ? "°" : "^") : string.Empty)</a></th>
            <th><a class="sort-link" href="@SortUrl("employee")">—отрудник @(currentSort == "employee" ? (currentDesc ? "°" : "^") : string.Empty)</a></th>
            <th><a class="sort-link" href="@SortUrl("accesspoint")">“очка доступа @(currentSort == "accesspoint" ? (currentDesc ? "°" : "^") : string.Empty)</a></th>
            <th><a class="sort-link" href="@SortUrl("device")">”стройство @(currentSort == "device" ? (currentDesc ? "°" : "^") : string.Empty)</a></th>
            <th><a class="sort-link" href="@SortUrl("result")">–езультат @(currentSort == "result" ? (currentDesc ? "°" : "^") : string.Empty)</a></th>
            <th><a class="sort-link" href="@SortUrl("reason")">ѕричина @(currentSort == "reason" ? (currentDesc ? "°" : "^") : string.Empty)</a></th>
        </tr>
        </thead>
        <tbody>
        @if (Model.Items.Any())
        {
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.EventTime.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</td>
                    <td>@(item.CardUid ?? "Ч")</td>
                    <td>@(item.Employee?.FullName ?? "Ќе указан")</td>
                    <td>@(item.AccessPoint?.Name ?? "Ќе указана")</td>
                    <td>@(item.Device?.Name ?? "Ќе указано")</td>
                    <td>@(item.AccessGranted ? "–азрешЄн" : "«апрещЄн")</td>
                    <td>@TranslateReason(item.Reason)</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center py-4 text-muted">Ќичего не найдено.</td>
            </tr>
        }
        </tbody>
    </table>
</div>

<nav class="mt-3" aria-label="ѕагинаци€ журнала">
    <ul class="pagination pagination-sm mb-0 justify-content-center">
        <li class="page-item @(Model.Page == 1 ? "disabled" : null)"><a class="page-link" href="@PageUrl(1)" aria-label="ѕерва€ страница">Ђ</a></li>
        <li class="page-item @(Model.Page == 1 ? "disabled" : null)"><a class="page-link" href="@PageUrl(Model.Page - 1)" aria-label="ѕредыдуща€ страница">Л</a></li>
        @for (var i = 1; i <= Model.TotalPages; i++)
        {
            if (i < Model.Page - 2 || i > Model.Page + 2)
            {
                continue;
            }

            <li class="page-item @(i == Model.Page ? "active" : null)"><a class="page-link" href="@PageUrl(i)">@i</a></li>
        }
        <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : null)"><a class="page-link" href="@PageUrl(Model.Page + 1)" aria-label="—ледующа€ страница">Ы</a></li>
        <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : null)"><a class="page-link" href="@PageUrl(Model.TotalPages)" aria-label="ѕоследн€€ страница">ї</a></li>
    </ul>
</nav>

