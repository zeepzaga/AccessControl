@model AccessControl.Domain.Entities.NfcCard
@{
    ViewData["Title"] = "Карта";
    var rules = ViewBag.AccessRules as IEnumerable<AccessControl.Domain.Entities.AccessRule> ?? Enumerable.Empty<AccessControl.Domain.Entities.AccessRule>();
}

<h2>Карта</h2>

<dl class="row">
    <dt class="col-sm-3">UID карты</dt>
    <dd class="col-sm-9">@Model.Uid</dd>

    <dt class="col-sm-3">Сотрудник</dt>
    <dd class="col-sm-9">@(Model.Employee?.FullName ?? "Не привязан")</dd>

    <dt class="col-sm-3">Тип карты</dt>
    <dd class="col-sm-9">@(Model.CardType == AccessControl.Domain.Enums.CardType.Employee ? "Сотрудник" : "Гость")</dd>

    <dt class="col-sm-3">Выдана</dt>
    <dd class="col-sm-9">@Model.IssuedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>

    <dt class="col-sm-3">Истекает</dt>
    <dd class="col-sm-9">@(Model.ExpiresAt?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "Не ограничен")</dd>

    <dt class="col-sm-3">Статус</dt>
    <dd class="col-sm-9">@(Model.IsActive ? "Активна" : "Неактивна")</dd>
</dl>

@if (rules.Any())
{
    <h5>Правила доступа сотрудника</h5>
    <ul>
        @foreach (var rule in rules)
        {
            <li>@rule.AccessPoint?.Name — @(rule.Schedule?.Name ?? "Без расписания")</li>
        }
    </ul>
}

<p>
    <a class="btn btn-secondary" asp-action="Index">Назад</a>
    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Изменить</a>
</p>
