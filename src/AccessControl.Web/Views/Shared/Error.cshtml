@model ErrorViewModel
@{
    ViewData["Title"] = "Ошибка";
}

<div class="card">
    <div class="card-body">
        <h1 class="page-title mb-3">@Model.Title</h1>
        <p class="page-subtitle mb-4">@Model.Message</p>

        <partial name="_ScreenError" model="Model" />

        <div class="mt-4 d-flex gap-2 flex-wrap">
            <a class="btn btn-primary" asp-controller="Home" asp-action="Index">На главную</a>
            <button type="button" class="btn btn-outline-secondary" onclick="history.back()">Назад</button>
        </div>
    </div>
</div>