@model AccessControl.Web.Models.EmployeeFormModel
@{
    ViewData["Title"] = "Редактировать сотрудника";
    var hasPhoto = Model.FaceImage is { Length: > 0 };
    var photoDataUrl = hasPhoto
        ? $"data:image/jpeg;base64,{Convert.ToBase64String(Model.FaceImage!)}"
        : null;
}

<h2>Редактировать сотрудника</h2>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <div class="mb-3">
        <label asp-for="FullName" class="form-label">ФИО</label>
        <input asp-for="FullName" class="form-control" />
        <span asp-validation-for="FullName" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="DepartmentNamesInput" class="form-label">Департаменты</label>
        <input asp-for="DepartmentNamesInput" class="form-control" placeholder="Например: IT, Безопасность, Администрация" />
        <div class="form-text">Укажи несколько департаментов через запятую.</div>
    </div>
    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label">Активен</label>
    </div>
    @if (hasPhoto)
    {
        <div class="mb-3">
            <label class="form-label d-block">Текущее фото</label>
            <img src="@photoDataUrl" alt="Фото сотрудника" class="img-thumbnail" style="max-width: 240px;" />
        </div>
    }
    <div class="mb-3">
        <label class="form-label" for="facePhoto">Обновить фото для биометрии</label>
        <input id="facePhoto" name="facePhoto" type="file" class="form-control" accept="image/*" />
        <div class="form-text">Если оставить поле пустым, текущее фото сохранится.</div>
        <span asp-validation-for="FaceImage" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Сохранить</button>
    <a class="btn btn-secondary" asp-action="Index">Отмена</a>
</form>
