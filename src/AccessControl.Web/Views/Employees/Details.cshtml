@model AccessControl.Domain.Entities.Employee
@{
    ViewData["Title"] = "Сотрудник";
    var hasPhoto = Model.FaceImage is { Length: > 0 };
    var photoDataUrl = hasPhoto
        ? $"data:image/jpeg;base64,{Convert.ToBase64String(Model.FaceImage!)}"
        : null;
}

<h2>Сотрудник</h2>

@if (hasPhoto)
{
    <div class="mb-4">
        <img src="@photoDataUrl" alt="Фото сотрудника" class="img-thumbnail" style="max-width: 240px;" />
    </div>
}

<dl class="row">
    <dt class="col-sm-3">ФИО</dt>
    <dd class="col-sm-9">@Model.FullName</dd>

    <dt class="col-sm-3">Департаменты</dt>
    <dd class="col-sm-9">@(Model.DepartmentNames.Any() ? string.Join(", ", Model.DepartmentNames) : "Не указаны")</dd>

    <dt class="col-sm-3">Статус</dt>
    <dd class="col-sm-9">@(Model.IsActive ? "Активен" : "Неактивен")</dd>

    <dt class="col-sm-3">Создан</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>

    <dt class="col-sm-3">Биометрия</dt>
    <dd class="col-sm-9">@(hasPhoto ? "Фото загружено" : "Фото не загружено")</dd>
</dl>

@if (Model.Cards.Any())
{
    <h5>Карты</h5>
    <ul>
        @foreach (var card in Model.Cards)
        {
            <li>@card.Uid (@(card.CardType == AccessControl.Domain.Enums.CardType.Employee ? "Сотрудник" : "Гость"))</li>
        }
    </ul>
}

<p>
    <a class="btn btn-secondary" asp-action="Index">Назад</a>
    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Изменить</a>
</p>