@model AccessControl.Domain.Entities.Employee
@{
    ViewData["Title"] = "Удалить сотрудника";
}

<h2>Удалить сотрудника</h2>

<div class="alert alert-warning">
    Вы уверены, что хотите удалить сотрудника <strong>@Model.FullName</strong>?
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Удалить</button>
    <a class="btn btn-secondary" asp-action="Index">Отмена</a>
</form>
