@model AccessControl.Web.ApiClient.DeviceResponse
@{
    ViewData["Title"] = "Устройство";
    var generatedToken = TempData["GeneratedDeviceToken"] as string;
    var generatedMessage = TempData["GeneratedDeviceTokenMessage"] as string;
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h2 class="mb-1">@Model.Name</h2>
        <div class="text-muted">Карточка устройства и управление device token.</div>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Редактировать</a>
        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id">Удалить</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(generatedToken))
{
    <div class="alert alert-warning">
        <div class="fw-semibold mb-2">Секретный токен устройства</div>
        <div class="mb-2">@generatedMessage</div>
        <code class="d-block p-2 bg-light border rounded">@generatedToken</code>
    </div>
}

<div class="card mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Локация</dt>
            <dd class="col-sm-9">@(Model.Location ?? "-")</dd>

            <dt class="col-sm-3">Точка доступа</dt>
            <dd class="col-sm-9">@(Model.AccessPointName ?? "Не привязана")</dd>

            <dt class="col-sm-3">Статус</dt>
            <dd class="col-sm-9">@(Model.IsActive ? "Активно" : "Неактивно")</dd>

            <dt class="col-sm-3">Подсказка токена</dt>
            <dd class="col-sm-9">@(Model.TokenHint ?? "Токен ещё не выпускался")</dd>

            <dt class="col-sm-3">Последняя ротация</dt>
            <dd class="col-sm-9">@(Model.TokenLastRotatedAt?.ToLocalTime().ToString("g") ?? "-")</dd>
        </dl>
    </div>
</div>

<form asp-action="RotateToken" asp-route-id="@Model.Id" method="post" class="d-inline">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-warning">Перевыпустить токен</button>
</form>
<a class="btn btn-secondary" asp-action="Index">Назад</a>
