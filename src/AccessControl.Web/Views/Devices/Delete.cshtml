@model AccessControl.Web.ApiClient.DeviceResponse
@{
    ViewData["Title"] = "Удалить устройство";
}

<h2>Удалить устройство</h2>
<p>Ты действительно хочешь удалить устройство <strong>@Model.Name</strong>?</p>

<dl class="row">
    <dt class="col-sm-3">Локация</dt>
    <dd class="col-sm-9">@(Model.Location ?? "-")</dd>

    <dt class="col-sm-3">Точка доступа</dt>
    <dd class="col-sm-9">@(Model.AccessPointName ?? "Не привязана")</dd>
</dl>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Удалить</button>
    <a class="btn btn-secondary" asp-action="Details" asp-route-id="@Model.Id">Отмена</a>
</form>
