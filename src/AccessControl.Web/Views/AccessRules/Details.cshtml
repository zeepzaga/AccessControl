@model AccessControl.Domain.Entities.AccessRule
@{
    ViewData["Title"] = "Правило доступа";
}

<h2>Правило доступа</h2>

<dl class="row">
    <dt class="col-sm-3">Точка доступа</dt>
    <dd class="col-sm-9">@(Model.AccessPoint?.Name ?? "Не указана")</dd>

    <dt class="col-sm-3">Расписание</dt>
    <dd class="col-sm-9">@(Model.Schedule?.Name ?? "Без расписания")</dd>

    <dt class="col-sm-3">Действует с</dt>
    <dd class="col-sm-9">@(Model.ValidFrom?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "Не ограничено")</dd>

    <dt class="col-sm-3">Действует по</dt>
    <dd class="col-sm-9">@(Model.ValidTo?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "Не ограничено")</dd>

    <dt class="col-sm-3">Статус</dt>
    <dd class="col-sm-9">@(Model.IsActive ? "Активно" : "Неактивно")</dd>
</dl>

<p>
    <a class="btn btn-secondary" asp-action="Index">Назад</a>
    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Изменить</a>
</p>