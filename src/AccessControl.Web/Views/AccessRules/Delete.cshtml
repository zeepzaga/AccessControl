@model AccessControl.Domain.Entities.AccessRule
@{
    ViewData["Title"] = "Удалить правило";
}

<h2>Удалить правило</h2>

<div class="alert alert-warning">
    Вы уверены, что хотите удалить правило для <strong>@Model.Employee?.FullName</strong>?
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Удалить</button>
    <a class="btn btn-secondary" asp-action="Index">Отмена</a>
</form>
