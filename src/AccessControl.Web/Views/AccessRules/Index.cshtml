@model AccessControl.Web.Models.PagedListViewModel<AccessControl.Domain.Entities.AccessRule>
@{
    ViewData["Title"] = "Правила доступа";
    var currentSort = ViewBag.Sort as string ?? "accesspoint";
    var currentDesc = ViewBag.Desc is bool b && b;
    Guid? accessPointId = ViewBag.AccessPointId is Guid accessPointIdValue ? accessPointIdValue : null;
    Guid? scheduleId = ViewBag.ScheduleId is Guid scheduleIdValue ? scheduleIdValue : null;
    bool? isActive = ViewBag.IsActive is bool isActiveValue ? isActiveValue : null;
    var accessPointOptions = ViewBag.AccessPointOptions as IEnumerable<AccessControl.Web.Models.SearchableSelectOptionViewModel> ?? Enumerable.Empty<AccessControl.Web.Models.SearchableSelectOptionViewModel>();
    var scheduleOptions = ViewBag.ScheduleOptions as IEnumerable<AccessControl.Web.Models.SearchableSelectOptionViewModel> ?? Enumerable.Empty<AccessControl.Web.Models.SearchableSelectOptionViewModel>();

    string SortUrl(string column) => Url.Action("Index", new
    {
        accessPointId,
        scheduleId,
        isActive,
        sort = column,
        desc = currentSort == column ? !currentDesc : false,
        page = 1,
        pageSize = Model.PageSize
    }) ?? "#";

    string PageUrl(int page) => Url.Action("Index", new
    {
        accessPointId,
        scheduleId,
        isActive,
        sort = currentSort,
        desc = currentDesc,
        page,
        pageSize = Model.PageSize
    }) ?? "#";
}

<h2>Правила доступа</h2>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <input type="hidden" name="sort" value="@currentSort" />
            <input type="hidden" name="desc" value="@currentDesc.ToString().ToLowerInvariant()" />
            <input type="hidden" name="pageSize" value="@Model.PageSize" />
            <div class="col-12 col-md-4">
                <label class="form-label">Точка доступа</label>
                <div class="searchable-select">
                    <input type="search" class="form-control searchable-select-filter" placeholder="Начните вводить название точки" data-select-filter-input="rule-accesspoint" />
                    <select name="accessPointId" class="form-select" data-select-filter-target="rule-accesspoint">
                        <option value="">Все точки доступа</option>
                        @foreach (var option in accessPointOptions)
                        {
                            <option value="@option.Value" data-filter-text="@option.SearchText.ToLowerInvariant()" selected="@option.Selected">@option.Label</option>
                        }
                    </select>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label">Расписание</label>
                <div class="searchable-select">
                    <input type="search" class="form-control searchable-select-filter" placeholder="Начните вводить название расписания" data-select-filter-input="rule-schedule" />
                    <select name="scheduleId" class="form-select" data-select-filter-target="rule-schedule">
                        <option value="">Все расписания</option>
                        @foreach (var option in scheduleOptions)
                        {
                            <option value="@option.Value" data-filter-text="@option.SearchText.ToLowerInvariant()" selected="@option.Selected">@option.Label</option>
                        }
                    </select>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label">Статус</label>
                <select name="isActive" class="form-select">
                    <option value="">Любой</option>
                    <option value="true" selected="@(isActive == true)">Активно</option>
                    <option value="false" selected="@(isActive == false)">Неактивно</option>
                </select>
            </div>
            <div class="col-12 d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-primary">Применить</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Сбросить</a>
                <a class="btn btn-outline-primary ms-auto" asp-action="Create">Добавить</a>
            </div>
        </form>
    </div>
</div>

<div class="table-toolbar d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-3">
    <form method="get" class="d-flex align-items-center gap-2 flex-nowrap table-page-size-form">
        <input type="hidden" name="accessPointId" value="@accessPointId" />
        <input type="hidden" name="scheduleId" value="@scheduleId" />
        <input type="hidden" name="isActive" value="@isActive?.ToString()?.ToLowerInvariant()" />
        <input type="hidden" name="sort" value="@currentSort" />
        <input type="hidden" name="desc" value="@currentDesc.ToString().ToLowerInvariant()" />
        <input type="hidden" name="page" value="1" />
        <label class="small text-muted text-nowrap" for="accessRulePageSize">Отображать на странице</label>
        <select id="accessRulePageSize" name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()">
            @foreach (var size in Model.PageSizeOptions)
            {
                <option value="@size" selected="@(size == Model.PageSize)">@size</option>
            }
        </select>
    </form>
    <div class="small text-muted">Показаны записи @Model.StartItem-@Model.EndItem из @Model.TotalCount</div>
</div>

<div class="table-responsive">
    <table class="table table-modern align-middle">
        <thead>
        <tr>
            <th><a class="sort-link" href="@SortUrl("accesspoint")">Точка доступа @(currentSort == "accesspoint" ? (currentDesc ? "Ў" : "^") : string.Empty)</a></th>
            <th><a class="sort-link" href="@SortUrl("schedule")">Расписание @(currentSort == "schedule" ? (currentDesc ? "Ў" : "^") : string.Empty)</a></th>
            <th>Период действия</th>
            <th><a class="sort-link" href="@SortUrl("status")">Статус @(currentSort == "status" ? (currentDesc ? "Ў" : "^") : string.Empty)</a></th>
            <th class="text-end">Действия</th>
        </tr>
        </thead>
        <tbody>
        @if (Model.Items.Any())
        {
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@(item.AccessPoint?.Name ?? "Не указана")</td>
                    <td>@(item.Schedule?.Name ?? "Без расписания")</td>
                    <td>@(item.ValidFrom?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "Сразу") - @(item.ValidTo?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "Без окончания")</td>
                    <td>@(item.IsActive ? "Активно" : "Неактивно")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Просмотр</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Изменить</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Удалить</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center py-4 text-muted">Ничего не найдено.</td>
            </tr>
        }
        </tbody>
    </table>
</div>

<nav class="mt-3" aria-label="Пагинация правил доступа">
    <ul class="pagination pagination-sm mb-0 justify-content-center">
        <li class="page-item @(Model.Page == 1 ? "disabled" : null)"><a class="page-link" href="@PageUrl(1)" aria-label="Первая страница">«</a></li>
        <li class="page-item @(Model.Page == 1 ? "disabled" : null)"><a class="page-link" href="@PageUrl(Model.Page - 1)" aria-label="Предыдущая страница">‹</a></li>
        @for (var i = 1; i <= Model.TotalPages; i++)
        {
            if (i < Model.Page - 2 || i > Model.Page + 2)
            {
                continue;
            }

            <li class="page-item @(i == Model.Page ? "active" : null)"><a class="page-link" href="@PageUrl(i)">@i</a></li>
        }
        <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : null)"><a class="page-link" href="@PageUrl(Model.Page + 1)" aria-label="Следующая страница">›</a></li>
        <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : null)"><a class="page-link" href="@PageUrl(Model.TotalPages)" aria-label="Последняя страница">»</a></li>
    </ul>
</nav>