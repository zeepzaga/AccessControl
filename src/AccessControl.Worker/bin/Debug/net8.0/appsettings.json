{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "AccessControlDb": "Host=localhost;Database=access_control;Username=postgres;Password=postgres"
  },
  "DeviceIntegration": {
    "Mode": "Mqtt",
    "Mqtt": {
      "Host": "localhost",
      "Port": 1883,
      "ClientId": "accesscontrol-worker",
      "TopicSubscribe": "accesscontrol/cards/read",
      "TopicPublishPrefix": "accesscontrol/cards/response"
    }
  },
  "Biometric": {
    "Mode": "Stub",
    "Http": {
      "BaseUrl": "http://localhost:8000",
      "VerifyPath": "/verify",
      "TimeoutSeconds": 5
    }
  }
}
